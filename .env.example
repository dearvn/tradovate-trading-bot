TRADOVATE_MODE=local

## OAuth callback URL — the public URL of this bot (e.g. https://yourbot.example.com)
## Users connect their Tradovate accounts via the UI at /connect — no passwords needed.
## Only CID and SECRET are required; USERNAME and PASSWORD are optional (legacy direct-auth).
TRADOVATE_OAUTH_CALLBACK_URL=http://localhost

## Live account credentials (set TRADOVATE_MODE=production to use these)
TRADOVATE_LIVE_USERNAME=
TRADOVATE_LIVE_PASSWORD=
TRADOVATE_LIVE_APP_ID=
TRADOVATE_LIVE_APP_VERSION=1.0
TRADOVATE_LIVE_CID=
TRADOVATE_LIVE_SECRET=

## Demo / Simulate account credentials (used when TRADOVATE_MODE != production)
TRADOVATE_DEMO_USERNAME=
TRADOVATE_DEMO_PASSWORD=
TRADOVATE_DEMO_APP_ID=
TRADOVATE_DEMO_APP_VERSION=1.0
TRADOVATE_DEMO_CID=
TRADOVATE_DEMO_SECRET=

## Slack
TRADOVATE_SLACK_ENABLED=false
TRADOVATE_SLACK_WEBHOOK_URL=
TRADOVATE_SLACK_CHANNEL=
TRADOVATE_SLACK_USERNAME=

## Local Tunnel
TRADOVATE_LOCAL_TUNNEL_ENABLED=false
### A local tunnel makes the bot accessible from the outside.
### Please set the subdomain of the local tunnel as a subdomain that only you can remember.
TRADOVATE_LOCAL_TUNNEL_SUBDOMAIN=default

## Feature Toggles
TRADOVATE_FEATURE_TOGGLE_NOTIFY_ORDER_CONFIRM=true
TRADOVATE_FEATURE_TOGGLE_NOTIFY_DEBUG=false
TRADOVATE_FEATURE_TOGGLE_NOTIFY_ORDER_EXECUTE=true

## Authentication
TRADOVATE_AUTHENTICATION_ENABLED=true
### Please set your own password.
TRADOVATE_AUTHENTICATION_PASSWORD=123456
TRADOVATE_JOBS_TRAILING_TRADE_BOT_OPTIONS_AUTHENTICATION_LOCK_LIST=true
TRADOVATE_JOBS_TRAILING_TRADE_BOT_OPTIONS_AUTHENTICATION_LOCK_AFTER=120

## PostgreSQL
TRADOVATE_POSTGRES_HOST=tradovate-postgres
TRADOVATE_POSTGRES_PORT=5432
TRADOVATE_POSTGRES_DATABASE=tradovate_bot
TRADOVATE_POSTGRES_USER=tradovate
TRADOVATE_POSTGRES_PASSWORD=tradovate_pass
